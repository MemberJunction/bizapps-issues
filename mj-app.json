{
  "$schema": "https://schema.memberjunction.org/mj-app/v1.json",
  "manifestVersion": 1,
  "name": "mj-bizapps-issues",
  "displayName": "Issues",
  "description": "Reusable case / issue / ticket primitives — Issue, IssueType, IssueStatus, IssueComment — the shared foundation for ticketing UX (Izzy) and the cloud-feedback destination",
  "version": "1.0.0",
  "license": "ISC",
  "icon": "fa-solid fa-life-ring",
  "publisher": {
    "name": "MemberJunction",
    "url": "https://memberjunction.com"
  },
  "repository": "https://github.com/MemberJunction/bizapps-issues",
  "mjVersionRange": ">=5.40.2 <6.0.0",
  "dependencies": {
    "mj-bizapps-tasks": {
      "version": ">=1.0.0 <2.0.0",
      "repository": "https://github.com/MemberJunction/bizapps-tasks"
    },
    "mj-bizapps-common": {
      "version": ">=5.30.0 <6.0.0",
      "repository": "https://github.com/MemberJunction/bizapps-common"
    }
  },
  "schema": {
    "name": "__mj_BizAppsIssues",
    "createIfNotExists": true
  },
  "migrations": {
    "directory": "migrations",
    "engine": "skyway"
  },
  "metadata": {
    "directory": "metadata"
  },
  "packages": {
    "server": [
      {
        "name": "@mj-biz-apps/issues-server",
        "role": "bootstrap",
        "startupExport": "LoadBizAppsIssuesServer"
      }
    ],
    "client": [
      {
        "name": "@mj-biz-apps/issues-ng",
        "role": "bootstrap",
        "startupExport": "LoadBizAppsIssuesClient"
      }
    ],
    "shared": [
      {
        "name": "@mj-biz-apps/issues-entities",
        "role": "library"
      },
      {
        "name": "@mj-biz-apps/issues-actions",
        "role": "library"
      },
      {
        "name": "@mj-biz-apps/issues-core",
        "role": "library"
      },
      {
        "name": "@mj-biz-apps/issues-core-entities-server",
        "role": "library"
      }
    ]
  },
  "code": {
    "visibility": "public",
    "sourceDirectory": "packages"
  },
  "categories": ["Business", "Support", "Ticketing"],
  "tags": ["issue", "ticket", "case", "feedback", "support"]
}
